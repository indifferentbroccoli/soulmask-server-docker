# Required
PUID=1000
PGID=1000

# IMPORTANT: SERVER_PASSWORD must be identical on both map servers.
SERVER_NAME=My Soulmask Server - Shifting Sands
SERVER_PASSWORD=changeme
ADMIN_PASSWORD=
GAME_MODE=pve
GAME_WORLD=DLC_Level01_Main
MAX_PLAYERS=20

GAME_PORT=8778
QUERY_PORT=27016
ECHO_PORT=18889
LISTEN_ADDRESS=0.0.0.0

SAVING_INTERVAL=600
BACKUP_INTERVAL=900

UPDATE_ON_START=true

# =============================================================================
# Cross-Map — Child server configuration
# This server connects to the main server for shared character data.
#
# If both containers run on the same host (default docker-compose setup),
# use the main server's Docker service name as the host:
#   CROSS_SERVER_CONNECT=soulmask-map1:20000
#
# If the main server runs on a different host, use its public IP instead:
#   CROSS_SERVER_CONNECT=<main-server-ip>:20000
# and expose port 20000 on the main server host.

SERVER_ID=2
CROSS_SERVER_CONNECT=soulmask-map1:20000
