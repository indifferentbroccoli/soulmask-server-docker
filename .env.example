# Required
PUID=1000
PGID=1000

SERVER_NAME=My Soulmask Server
SERVER_PASSWORD=
ADMIN_PASSWORD=
GAME_MODE=pve
GAME_WORLD=Level01_Main
MAX_PLAYERS=20

GAME_PORT=8777
QUERY_PORT=27015
ECHO_PORT=18888
LISTEN_ADDRESS=0.0.0.0

SAVING_INTERVAL=600
BACKUP_INTERVAL=900

UPDATE_ON_START=true

# =============================================================================
# Cross-Map
# Run one container per map and link them together for cross-map character travel.

# Unique integer ID for this server instance (required when using cross-server).
# Each server in the cluster must have a different value.
#SERVER_ID=1

# Main server only: broadcast port for child servers to connect to.
#CROSS_SERVER_MAIN_PORT=20000

# Child server only: address of the main server (host:port).
#CROSS_SERVER_CONNECT=192.168.0.2:20000
